{
  "name": "redgifs-downloader",
  "version": "4.0.0",
  "description": "RedGifs Downloader — Electron + React desktop app",
  "author": "privacytop",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test": "vitest run",
    "test:main": "ELECTRON_RUN_AS_NODE=1 electron ./node_modules/vitest/vitest.mjs run --config vitest.main.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/space-mono": "^5.2.9",
    "better-sqlite3": "^11.1.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.0.5"
  },
  "build": {
    "appId": "com.privacytop.redgifs-downloader",
    "productName": "RedGifs Downloader",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "npmRebuild": false,
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "RedGifs-Downloader-${version}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "RedGifs-Downloader-${version}-portable.${ext}"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "AudioVideo",
      "maintainer": "privacytop",
      "artifactName": "RedGifs-Downloader-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "privacytop",
      "repo": "redgifs-downloader",
      "releaseType": "release"
    }
  }
}
